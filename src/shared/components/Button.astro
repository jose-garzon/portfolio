---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  href?: string;
  target?: string;
  rel?: string;
}

const { variant = 'primary', href, target, rel } = Astro.props;
const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['btn', `btn--${variant}`]}
  {...(href ? { href, target, rel } : {})}
>
  <slot />
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: 600;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition:
      transform var(--duration-normal) var(--ease-spring),
      box-shadow var(--duration-normal) var(--ease-out),
      background var(--duration-normal) var(--ease-out);
  }

  .btn--primary {
    background: var(--color-accent);
    color: #ffffff;
    box-shadow: 0 0 0 0 rgba(255, 45, 85, 0);
  }

  .btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-accent-lg), 0 0 40px rgba(255, 45, 85, 0.2);
    background: var(--color-accent-warm);
  }

  .btn--primary:active {
    transform: translateY(0) scale(0.98);
  }

  .btn--primary :global(svg) {
    transition: transform var(--duration-normal) var(--ease-spring);
  }

  .btn--primary:hover :global(svg) {
    transform: translateX(3px);
  }

  .btn--secondary {
    background: var(--color-surface-raised);
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .btn--secondary:hover {
    transform: translateY(-2px);
    border-color: var(--color-text-muted);
    background: var(--color-surface);
  }

  .btn--secondary:active {
    transform: translateY(0) scale(0.98);
  }

  .btn--ghost {
    background: transparent;
    color: var(--color-text-muted);
    padding: var(--space-2) var(--space-4);
  }

  .btn--ghost:hover {
    color: var(--color-text);
    background: var(--color-surface);
    transform: translateY(-1px);
  }

  .btn--ghost:active {
    transform: translateY(0) scale(0.98);
  }
</style>
