---
interface Props {
  variant?: 'muted' | 'accent';
  pill?: boolean;
}

const { variant = 'muted', pill = false } = Astro.props;
---

<span class:list={['badge', `badge--${variant}`, { 'badge--pill': pill }]}>
  <slot />
</span>

<style>
  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: 4px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    cursor: default;
    transition:
      color 0.2s var(--ease-out),
      border-color 0.2s var(--ease-out),
      background 0.2s var(--ease-out),
      transform 0.2s var(--ease-out),
      box-shadow 0.2s var(--ease-out);
  }

  .badge--pill {
    border-radius: 9999px;
  }

  .badge--muted {
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    color: var(--color-text-muted);
  }

  .badge--muted:hover {
    color: var(--color-accent);
    border-color: rgba(126, 232, 162, 0.45);
    background: var(--color-accent-dim);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(126, 232, 162, 0.08);
  }

  .badge--accent {
    border: 1px solid rgba(126, 232, 162, 0.2);
    background: var(--color-accent-dim);
    color: var(--color-accent);
  }

  .badge--accent:hover {
    background: rgba(126, 232, 162, 0.25);
    border-color: rgba(126, 232, 162, 0.55);
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(126, 232, 162, 0.12);
  }
</style>
