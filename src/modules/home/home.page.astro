---
import Layout from '../../layouts/Layout.astro';
import Header from '../../shared/components/Header/Header';
import Hero from './components/Hero.astro';
import About from './components/About.astro';
import Experience from './components/Experience.astro';
import ProjectsPage from '../projects/projects.page.astro';
---

<Layout title="José Garzón — Software Engineer">
  <Header client:load />
  <main>
    <Hero />
    <About />
    <Experience />
    <ProjectsPage />
  </main>
  <footer class="site-footer">
    <div class="container">
      <p>
        <span class="footer-mono">© 2026 José Garzón</span>
        <span class="footer-sep">·</span>
        <a href="/blog">Writing</a>
        <span class="footer-sep">·</span>
        <a href="https://github.com/jose-garzon" target="_blank" rel="noopener">GitHub</a>
      </p>
    </div>
  </footer>
</Layout>

<style>
  .site-footer {
    padding-block: var(--space-8);
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-section);
  }

  .site-footer p {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer-mono {
    font-family: var(--font-mono);
  }

  .footer-sep {
    color: var(--color-border);
  }

  .site-footer a {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .site-footer a:hover {
    color: var(--color-text);
  }
</style>
