---
---

<section class="hero">
  <div class="container">
    <p class="hero-label">
      <span class="cursor">&gt;</span> jose_garzon --role=<span class="accent">"software-engineer"</span>
    </p>
    <h1 class="hero-name">José Garzón</h1>
    <p class="hero-tagline">
      Building software at the intersection of AI and product.
      <br />Focused on LLM tooling, developer experience, and shipping things that matter.
    </p>

    <ul class="hero-links">
      <li>
        <a href="https://github.com/jose-garzon" target="_blank" rel="noopener" class="link-pill">
          GitHub
        </a>
      </li>
      <li>
        <a href="https://linkedin.com/in/jose-garzon" target="_blank" rel="noopener" class="link-pill">
          LinkedIn
        </a>
      </li>
      <li>
        <a href="mailto:jose@example.com" class="link-pill">
          Email
        </a>
      </li>
      <li>
        <a href="/resume.pdf" target="_blank" rel="noopener" class="link-pill link-pill--accent">
          Resume
        </a>
      </li>
    </ul>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding-top: var(--nav-height);
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-5);
  }

  .cursor {
    color: var(--color-accent);
    margin-right: var(--space-1);
  }

  .accent {
    color: var(--color-accent);
  }

  .hero-name {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.1;
    margin-bottom: var(--space-5);
    letter-spacing: -0.02em;
  }

  .hero-tagline {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 52ch;
    line-height: 1.65;
    margin-bottom: var(--space-10);
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    list-style: none;
  }

  .link-pill {
    display: inline-block;
    padding: var(--space-2) var(--space-5);
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .link-pill:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .link-pill--accent {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .link-pill--accent:hover {
    background: var(--color-accent-dim);
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
</style>
