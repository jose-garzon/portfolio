---
import Badge from '../../../shared/components/Badge.astro';
import { about } from '../../../shared/data/about';
---

<section id="about" class="section">
  <div class="container">
    <p class="section-label scanlines reveal">about</p>

    <div class="about-grid">
      <div class="about-text">
        <h2 class="about-heading scanlines reveal">
          <span class="glitch-inner" data-text={about.heading}>
            Crafting software that<br />
            <em>actually ships.</em>
          </span>
        </h2>
        <div class="about-paragraphs reveal">
          {about.paragraphs.map((p) => (
            <p>{p}</p>
          ))}
        </div>
      </div>

      <div class="about-sidebar">
        <div class="skills-panel reveal">
          <p class="panel-label">Tools &amp; Technologies</p>
          <ul class="skills-list reveal-stagger">
            {about.skills.map((skill) => (
              <li><Badge>{skill}</Badge></li>
            ))}
          </ul>
        </div>

        <div class="current-panel reveal">
          <p class="panel-label">Currently</p>
          <ul class="current-list">
            {about.currently.map((item) => (
              <li>
                <span class="current-icon">→</span>
                {item.text}{item.highlight && <> <strong>{item.highlight}</strong></>}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: var(--space-16);
    align-items: start;
  }

  .about-heading {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    letter-spacing: -0.03em;
    margin-bottom: var(--space-8);
  }

  .about-heading em {
    font-style: normal;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-warm));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .about-paragraphs {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .about-paragraphs p {
    color: var(--color-text-muted);
    line-height: 1.8;
    font-size: var(--text-base);
  }

  .about-sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    position: sticky;
    top: calc(var(--nav-height) + var(--space-8));
  }

  .panel-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-4);
  }

  .skills-panel,
  .current-panel {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  .current-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    list-style: none;
  }

  .current-list li {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .current-list strong {
    color: var(--color-text);
    font-weight: 500;
  }

  .current-icon {
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .about-sidebar {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .about-sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>
