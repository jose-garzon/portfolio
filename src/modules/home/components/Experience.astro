---
import Badge from '../../../shared/components/Badge.astro';
import { experience } from '../data/experience';
---

<section id="experience" class="section">
  <div class="container">
    <p class="section-label scanlines reveal">experience</p>
    <h2 class="section-title scanlines reveal"><span data-text="Work History">Work History</span></h2>

    <ol class="timeline">
      {experience.map((job, index) => (
        <li class="timeline-item reveal">
          <div class="timeline-indicator" aria-hidden="true">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-content">
            <div class="job-card">
              <div class="job-header">
                <div class="job-title-group">
                  <h3 class="job-role" data-text={job.role}>{job.role}</h3>
                  <p class="job-company">{job.company}</p>
                </div>
                <span class="job-period">{job.period}</span>
              </div>

              <p class="job-description">{job.description}</p>

              <ul class="job-bullets">
                {job.bullets.map((bullet) => (
                  <li>
                    <span class="bullet-marker" aria-hidden="true">▸</span>
                    {bullet}
                  </li>
                ))}
              </ul>

              <ul class="stack-chips">
                {job.stack.map((tech) => (
                  <li><Badge variant="accent">{tech}</Badge></li>
                ))}
              </ul>
            </div>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 0;
    list-style: none;
    position: relative;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 28px 1fr;
    gap: var(--space-6);
    position: relative;
  }

  .timeline-indicator {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: var(--space-5);
  }

  .timeline-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--color-accent);
    background: var(--color-bg);
    flex-shrink: 0;
    transition:
      background var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      transform var(--duration-normal) var(--ease-spring);
    z-index: 1;
  }

  .timeline-item:hover .timeline-dot {
    background: var(--color-accent);
    box-shadow: 0 0 0 4px var(--color-accent-dim), var(--shadow-accent);
    transform: scale(1.2);
  }

  .timeline-line {
    width: 1px;
    flex-grow: 1;
    background: linear-gradient(to bottom, var(--color-border), transparent);
    margin-top: var(--space-2);
    min-height: var(--space-8);
  }

  .timeline-item:last-child .timeline-line {
    display: none;
  }

  .timeline-content {
    padding-bottom: var(--space-10);
  }

  .timeline-item:last-child .timeline-content {
    padding-bottom: 0;
  }

  .job-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-8);
    transition:
      border-color var(--duration-normal) var(--ease-out),
      box-shadow var(--duration-normal) var(--ease-out),
      background var(--duration-normal) var(--ease-out);
  }

  .timeline-item:hover .job-card {
    border-color: var(--color-accent-dim);
    box-shadow: var(--shadow-accent), inset 0 0 0 1px var(--color-accent-glow);
    background: var(--color-surface-raised);
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: var(--space-4);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .job-role {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-1);
    letter-spacing: -0.01em;
  }

  .job-company {
    font-size: var(--text-sm);
    color: var(--color-accent);
    font-weight: 500;
    font-family: var(--font-mono);
  }

  .job-period {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    white-space: nowrap;
    padding: var(--space-1) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    background: var(--color-surface-raised);
    flex-shrink: 0;
  }

  .job-description {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-5);
    line-height: 1.7;
  }

  .job-bullets {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-6);
  }

  .job-bullets li {
    display: flex;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    align-items: baseline;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .job-bullets li:hover {
    color: var(--color-text);
  }

  .bullet-marker {
    color: var(--color-accent);
    font-size: 0.6em;
    flex-shrink: 0;
    translate: 0 0.1em;
  }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  @media (max-width: 640px) {
    .timeline-item {
      grid-template-columns: 20px 1fr;
      gap: var(--space-4);
    }

    .job-card {
      padding: var(--space-5) var(--space-5);
    }
  }
</style>
