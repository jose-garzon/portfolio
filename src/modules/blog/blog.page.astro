---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../shared/components/Header/Header';
import BlogCard from './components/BlogCard.astro';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  title="Writing — José Garzón"
  description="Engineering notes on LLMs, TypeScript, Python, and building software."
>
  <Header client:load />
  <main class="blog-main">
    <div class="container">
      <header class="blog-header">
        <p class="section-label scanlines">writing</p>
        <h1 class="blog-title scanlines"><span data-text="Writing">Writing</span></h1>
        <p class="blog-subtext">
          Engineering notes on LLMs, TypeScript, Python, and what I'm figuring out.
          Learning in public.
        </p>
      </header>

      {posts.length === 0 ? (
        <p class="empty">No posts yet — check back soon.</p>
      ) : (
        <ul class="posts-list reveal-stagger">
          {posts.map((post) => (
            <li>
              <BlogCard
                slug={post.id}
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
              />
            </li>
          ))}
        </ul>
      )}
    </div>
  </main>
</Layout>

<style>
  .blog-main {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-section);
  }

  .blog-header {
    margin-bottom: var(--space-12);
    max-width: 600px;
  }

  .blog-title {
    font-size: var(--text-4xl);
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: var(--space-4);
  }

  .blog-subtext {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .posts-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
  }

  .empty {
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
  }
</style>
