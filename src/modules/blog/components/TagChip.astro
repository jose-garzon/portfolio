---
interface Props {
  tag: string;
}
const { tag } = Astro.props;
---

<span class="tag-chip">{tag}</span>

<style>
  .tag-chip {
    display: inline-block;
    padding: 2px 10px;
    border: 1px solid var(--color-border);
    border-radius: 9999px;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }
</style>
