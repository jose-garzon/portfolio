---
import Layout from '../../../layouts/Layout.astro';
import TagChip from './TagChip.astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
  wordCount: number;
}

const { title, description, pubDate, tags, wordCount } = Astro.props;

const readingTime = Math.max(1, Math.ceil(wordCount / 200));
const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Layout title={`${title} — José Garzón`} description={description}>
  <div class="container post-container">
    <nav class="post-nav">
      <a href="/blog" class="back-link">← Back to writing</a>
    </nav>

    <header class="post-header">
      <time class="post-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
      <h1 class="post-title">{title}</h1>
      <div class="post-meta">
        <span class="reading-time">{readingTime} min read</span>
        {tags.length > 0 && (
          <ul class="tag-list">
            {tags.map((tag) => <li><TagChip tag={tag} /></li>)}
          </ul>
        )}
      </div>
    </header>

    <div class="prose">
      <slot />
    </div>
  </div>
</Layout>

<style>
  .post-container {
    padding-top: var(--space-10);
    padding-bottom: var(--space-section);
  }

  .post-nav {
    margin-bottom: var(--space-10);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color 0.15s;
  }

  .back-link:hover {
    color: var(--color-text);
  }

  .post-header {
    margin-bottom: var(--space-12);
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  .post-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .post-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--color-text);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-5);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .reading-time {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }
</style>
