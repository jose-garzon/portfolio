---
import TagChip from './TagChip.astro';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  tags: string[];
}

const { slug, title, description, pubDate, tags } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="blog-card">
  <article>
    <time class="blog-date" datetime={pubDate.toISOString()}>{formattedDate}</time>
    <h2 class="blog-title">{title}</h2>
    <p class="blog-description">{description}</p>
    {tags.length > 0 && (
      <ul class="tag-list">
        {tags.map((tag) => (
          <li><TagChip tag={tag} /></li>
        ))}
      </ul>
    )}
    <span class="read-more">Read more →</span>
  </article>
</a>

<style>
  .blog-card {
    display: block;
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-surface);
    transition: border-color 0.2s ease;
  }

  .blog-card:hover {
    border-color: var(--color-accent);
  }

  .blog-date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .blog-title {
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-3);
    line-height: 1.3;
  }

  .blog-description {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.65;
    margin-bottom: var(--space-4);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin-bottom: var(--space-4);
  }

  .read-more {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-accent);
  }
</style>
